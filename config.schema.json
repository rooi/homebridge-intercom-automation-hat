{
  "pluginAlias": "IntercomAutomationHAT",
  "pluginType": "platform",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Intercom",
        "required": true
      },
      "bellTimeout": {
        "title": "Bell Timeout",
        "type": "string",
        "default": "1000",
        "required": false
      },
      "lockTimeout": {
        "title": "Lock Timeout",
        "type": "string",
        "default": "1000",
        "required": false
      },
      "voltageLowLimit": {
        "title": "Voltage Low Limit",
        "type": "string",
        "default": "0.03",
        "required": false
      },
      "pythonPath": {
        "title": "Python Path",
        "type": "string",
        "default": "/home/pi/venvs/automationhat/bin/python",
        "description": "Path to the Python executable or virtual environment Python binary."
      }
    }
  }
}
